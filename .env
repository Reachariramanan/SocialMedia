# Lightpanda CDP endpoint
LIGHTPANDA_CDP_URL=http://127.0.0.1:9222

# vLLM OpenAI-compatible endpoint (container vllm_qwen36_35b)
VLLM_BASE_URL=http://192.168.200.23:11642/v1
VLLM_MODEL=qwen36-35b

# Bot run behavior
POLL_INTERVAL_SEC=300

# SearXNG configuration
SEARXNG_HOST=0.0.0.0
SEARXNG_PORT=8080
SEARXNG_SECRET_KEY=change_me_to_a_random_secure_string

# Tweet extraction token budget
# TWEET_MAX_CHARS  — max characters per tweet body (~80 tokens at 320 chars)
TWEET_MAX_CHARS=400
# TWEET_MAX_PER_URL — top N tweets per URL, ranked by engagement (likes + 2×retweets)
TWEET_MAX_PER_URL=20
